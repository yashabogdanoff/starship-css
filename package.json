{
  "name": "starship-css",
  "version": "0.0.3",
  "description": "CSS framework that styles HTML to look like the Unreal Engine 5 editor (Slate UI). Inspired by Unreal Engine — not affiliated with Epic Games.",
  "main": "dist/starship.js",
  "style": "dist/starship.css",
  "exports": {
    ".": {
      "style": "./dist/starship.css",
      "default": "./dist/starship.js"
    },
    "./css": "./dist/starship.css",
    "./css.min": "./dist/starship.min.css",
    "./js": "./dist/starship.js",
    "./js.min": "./dist/starship.min.js",
    "./scss/*": "./src/scss/*"
  },
  "sideEffects": [
    "dist/starship.css",
    "dist/starship.min.css",
    "dist/starship.js",
    "dist/starship.min.js"
  ],
  "files": [
    "dist/",
    "src/scss/",
    "src/js/",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build:css": "sass src/scss/starship.scss dist/starship.css",
    "build:css-min": "postcss dist/starship.css -o dist/starship.min.css --map",
    "build:js": "node -e \"require('fs').copyFileSync('src/js/starship.js','dist/starship.js')\"",
    "build:js-min": "terser src/js/starship.js -c -m --comments=/^\\!/ --source-map \"url='starship.min.js.map'\" -o dist/starship.min.js",
    "build:mirror-docs": "node -e \"const fs=require('fs');fs.rmSync('docs/dist',{recursive:true,force:true});fs.mkdirSync('docs/dist',{recursive:true});for(const f of fs.readdirSync('dist'))fs.copyFileSync('dist/'+f,'docs/dist/'+f);\"",
    "build": "npm run build:css && npm run build:css-min && npm run build:js && npm run build:js-min && npm run build:mirror-docs",
    "watch": "sass --watch src/scss/starship.scss dist/starship.css",
    "prepublishOnly": "npm run build",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "keywords": [
    "css",
    "ui",
    "unreal-engine",
    "slate",
    "ue5",
    "dark-theme",
    "editor-ui"
  ],
  "license": "MIT",
  "devDependencies": {
    "@storybook/html-vite": "^10.3.6",
    "cssnano": "^7.0.0",
    "postcss": "^8.4.0",
    "postcss-cli": "^11.0.0",
    "sass": "^1.77.0",
    "storybook": "^10.3.6",
    "storybook-addon-pseudo-states": "^10.3.6",
    "terser": "^5.47.1"
  }
}
